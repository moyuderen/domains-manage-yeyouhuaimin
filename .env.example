# Supabase 项目 URL（客户端 & 服务端共用）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase 匿名密钥（仅限客户端使用，受 RLS 保护）
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase 服务端密钥（仅限服务端使用，绕过 RLS，禁止暴露到客户端）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 访问密钥，用于登录验证
ACCESS_KEY=your-access-key

# Session 签名密钥，用于加密访问令牌（至少 32 位随机字符）
ACCESS_SESSION_SIGNING_KEY=replace-with-32-plus-random-chars

# Session 最大有效期，单位秒（默认 28800 = 8 小时）
ACCESS_SESSION_MAX_AGE_SECONDS=28800

# Cron 端点鉴权密钥（外部定时任务调用 /api/cron/* 时使用）
CRON_SECRET=your-cron-secret-here

# CLI / 服务器 / Docker / GitHub Actions 运行定时任务时同样需要上述服务端环境变量
# 推荐通过 `npm run job -- domain-expiry-check <trigger-source>` 调用平台无关 job 入口
# trigger-source 会写入 job_runs.trigger_source，用来区分来源平台（如 vercel-cron / github-actions / server-cron / docker-cron）
